{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/cchmc/nf-encode-chip/master/nextflow_schema.json",
    "title": " cchmc/nf-encode-chip parameters",
    "description": "",
    "type": "object",
    "defs": {
        "input_output_options": {
            "title": "Input/output options",
            "type": "object",
            "fa_icon": "fas fa-terminal",
            "description": "Define where the pipeline should find input data and save output data.",
            "required": [
                "input",
                "outdir"
            ],
            "properties": {
                "input": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "schema": "assets/schema_input.json",
                    "mimetype": "text/csv",
                    "pattern": "^\\S+\\.csv$",
                    "description": "Path to comma-separated file containing information about the samples in the experiment.",
                    "help_text": "You will need to create a design file with information about the samples in your experiment before running the pipeline. Use this parameter to specify its location. It has to be a comma-separated file with 3 columns, and a header row.",
                    "fa_icon": "fas fa-file-csv"
                },
                "outdir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "The output directory where the results will be saved. You have to use absolute paths to storage on Cloud infrastructure.",
                    "fa_icon": "fas fa-folder-open"
                },
                "fasta": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "mimetype": "text/plain",
                    "pattern": "^\\S+\\.fn?a(sta)?(\\.gz)?$",
                    "description": "Path to fasta file containing the genome sequence.",
                    "help_text": "Fasta files can be in .fa or .fasta format, and optionally gzipped."
                },
                "genome": {
                    "type": "string",
                    "description": "Name of a genome to use. Fills in other values with presets if those are not supplied."
                },
                "gtf": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "mimetype": "text/plain",
                    "pattern": "^\\S+\\.gtf(\\.gz)?$",
                    "description": "Path to a .gtf or .gtf.gz file containing genome annotations."
                },
                "mito_chr_name": {
                    "type": "string",
                    "description": "Name of the mitochondria chromosome in the genome fasta",
                    "help_text": "Provide this to be able to identify and remove mitochrondia-related peaks / sequences.",
                    "default": "chrM"
                },
                "bowtie2_index": {
                    "type": "string",
                    "format": [
                        "file-path",
                        "directory-path"
                    ],
                    "exists": true,
                    "description": "Path folder or tar file containing bowtie2 indices."
                },
                "pseudorep_seed": {
                    "type": "integer",
                    "default": 42,
                    "description": "Pseudoreplication seed.",
                    "help_text": "Pseudoreplication seed."
                },
                "exclusion_peaks": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "mimetype": "text/plain",
                    "description": "Path to exclusion peak file.",
                    "help_text": ""
                },
                "save_reference": {
                    "type": "boolean",
                    "default": false,
                    "description": "Save genome files like indices."
                }
            }
        },
        "fastq_options": {
            "title": "FASTQ-related options",
            "type": "object",
            "description": "",
            "properties": {
                "skip_adapter_trimming": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disables adapter trimming."
                },
                "save_trimmed_fastq": {
                    "type": "boolean",
                    "default": false,
                    "description": "Save fastq files after trimming."
                },
                "adapter_1": {
                    "type": "string",
                    "default": null,
                    "description": "Specify an adapter sequence to trim from read1 with fastp. If not specified, fastp will try to auto-detect the adapter. If specified, this will override auto detection for any sample without a specified adapter."
                },
                "adapter_2": {
                    "type": "string",
                    "default": null,
                    "description": "Specify an adapter sequence to trim from read2 with fastp. If not specified, fastp will try to auto-detect the adapter. If specified, this will override auto detection for any sample without a specified adapter."
                },
                "fastp_detect_adapter_for_pe": {
                    "type": "boolean",
                    "default": false,
                    "description": "fastp uses overlap analysis to trim PE reads by default. Enabling this will force fastp to use adapter detection instead."
                },
                "fastp_extra_args": {
                    "type": "string",
                    "description": "Extra arguments to pass to fastp. Adapter options are specified in the other parameters, but you could add them here."
                },
                "seqkit_seed": {
                    "type": "integer",
                    "default": 12345,
                    "description": "Seed for random number generator in seqkit."
                },
                "save_subsampled_fastq": {
                    "type": "boolean",
                    "default": false,
                    "description": "Save fastq files after subsampling. Only files that are subsampled will be saved."
                }
            }
        },
        "alignment_options": {
            "title": "Alignment options",
            "type": "object",
            "description": "Options related to read alignment.",
            "properties": {
                "aligner": {
                    "type": "string",
                    "default": "bowtie2",
                    "enum": [
                        "bowtie2"
                    ],
                    "description": "The aligner to use for read alignment.",
                    "help_text": "The aligner to use for read alignment. Currently only bowtie2."
                },
                "skip_align": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skips read alignment."
                },
                "local_mode": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable Bowtie2's local mode.",
                    "help_text": "Enable Bowtie2's local mode."
                },
                "mapq_threshold": {
                    "type": "integer",
                    "default": 30,
                    "description": "MAPQ threshold to apply for alignment filtering."
                },
                "spp_subsample_fragments": {
                    "type": "integer",
                    "default": 10000000,
                    "description": "Number of fragments to subsample for strand cross-correlation analysis. If 0, no subsampling is performed."
                },
                "skip_low_mapq_filter": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disables filtering of low MAPQ reads."
                },
                "skip_rm_duplicates": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disables filtering of duplicated reads."
                },
                "save_filtered_bam": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save filtered BAM files."
                },
                "skip_pseudoreplication": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disables pseudoreplicate analysis."
                },
                "save_sample_tagalign": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save tagAlign files for samples."
                },
                "save_pr_tagalign": {
                    "type": "boolean",
                    "default": false,
                    "description": "Save tagAlign files for pseudoreplicates."
                },
                "save_pooled_tagalign": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save tagAlign files for pooled replicates."
                },
                "markdup_method": {
                    "type": "string",
                    "default": "sambamba",
                    "enum": [
                        "sambamba",
                        "picard"
                    ],
                    "description": "Method to use for marking duplicates."
                }
            }
        },
        "encode_peak_options": {
            "title": "Options for ENCODE-style peak analysis",
            "type": "object",
            "description": "Options for ENCODE-style peak calling.",
            "properties": {
                "gensz": {
                    "type": [
                        "integer",
                        "string"
                    ],
                    "description": "Size of the mappable genome to use for MACS2. Can be a string (hs, mm) or int"
                },
                "encode_macs2_pthresh": {
                    "type": "number",
                    "default": 0.01,
                    "description": "Initial p-value to use for thresholding in MACS2 (ENCODE)."
                },
                "encode_macs2_ext_args": {
                    "type": "string",
                    "default": "-f BED -p 0.01 --nomodel --shift 0 --keep-dup all",
                    "description": "Arguments passed to MACS2 by ENCODE when calling peaks. Fragment length is automatically calculated. To generate ENCODE's signal tracks, add '-B --SPMR' to this string."
                },
                "skip_peak_filtering": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disables peak postprocessing."
                },
                "chr_filter": {
                    "type": "string",
                    "default": "chr[0-9XY]+",
                    "description": "Regex string to apply to peaks."
                },
                "encode_max_macs2_peaks": {
                    "type": "integer",
                    "default": 500000,
                    "description": "Maximum number of peaks to keep after calling peaks.",
                    "help_text": "Setting this to 0 will disable this cutoff."
                },
                "encode_macs2_post_qfilter": {
                    "type": "number",
                    "default": 0.05,
                    "description": "A q-filter to apply to ENCODE's peak outputs. This does NOT affect anything inside the ENCODE steps, and generates a new set of peaks."
                }
            }
        },
        "encode_reproducibility_options": {
            "title": "ENCODE Reproducibility options",
            "type": "object",
            "description": "Options related to reproducibility analysis of peak files.",
            "properties": {
                "idr_threshold_col": {
                    "type": "string",
                    "default": "p.value",
                    "enum": [
                        "p.value",
                        "signal.value",
                        "q.value"
                    ],
                    "description": "The narrowPeak column to use for IDR thresholding."
                },
                "idr_threshold": {
                    "type": "number",
                    "default": 0.05,
                    "description": "IDR threshold to use."
                },
                "idr_extra_args": {
                    "type": "string",
                    "default": "--use-best-multisummit-IDR",
                    "description": "Extra arguments to pass to IDR."
                },
                "skip_idr": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disables IDR."
                },
                "skip_overlap": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disables peak overlap analysis."
                }
            }
        },
        "homer_options": {
            "title": "HOMER options",
            "type": "object",
            "description": "Options for HOMER motif analysis.",
            "properties": {
                "skip_homer_findmotifsgenome": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip HOMER findMotifsGenome.pl."
                },
                "skip_homer_annotatepeaks": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip HOMER annotatePeaks.pl."
                },
                "homer_log2_mode": {
                    "type": "boolean",
                    "default": false,
                    "description": "Use log2-based scoring for HOMER."
                },
                "homer_motif_lib": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "description": "Path to motif library to use for HOMER."
                },
                "homer_findmotifsgenome_ext_args": {
                    "type": "string",
                    "default": "-size given -nomotif",
                    "description": "Additional arguments to pass to HOMER findMotifsGenome.pl."
                }
            }
        },
        "encode_options": {
            "title": "ENCODE options",
            "type": "object",
            "description": "Options for ENCODE-style analysis.",
            "properties": {
                "use_encode_overlap": {
                    "type": "boolean",
                    "default": false,
                    "description": "Use ENCODE's overlap analysis calculation instead of an updated bedtools command."
                }
            }
        },
        "metagenomics_options": {
            "title": "Metagenomics options",
            "type": "object",
            "description": "Options for metagenomics analysis.",
            "properties": {
                "kraken2_db": {
                    "type": "string",
                    "format": [
                        "file-path",
                        "directory-path"
                    ],
                    "exists": true,
                    "description": "Path folder or tar file containing kraken2 database."
                },
                "kraken2_ext_args": {
                    "type": "string",
                    "default": "--output - --report-minimizer-data --use-names",
                    "description": "Additional arguments to pass to kraken2."
                },
                "skip_kraken2": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip Kraken2."
                },
                "skip_sourmash": {
                    "type": "boolean",
                    "default": true,
                    "description": "Skip sourmash."
                },
                "sourmash_db": {
                    "type": "string",
                    "format": [
                        "file-path",
                        "directory-path"
                    ],
                    "exists": true,
                    "description": "Path folder or tar file containing sourmash database."
                },
                "sourmash_ext_args": {
                    "type": "string",
                    "default": "-p abund",
                    "description": "Additional parameters to pass to sourmash"
                }
            }
        },
        "trackhub_options": {
            "title": "Track Hub options",
            "type": "object",
            "description": "Track Hub options for UCSC, etc.",
            "properties": {
                "ucsc_trackhub_shortlabel": {
                    "type": "string",
                    "default": "ChIP-seq",
                    "description": "Short label for the UCSC trackhub."
                },
                "ucsc_trackhub_longlabel": {
                    "type": "string",
                    "default": "ChIP-seq data",
                    "description": "Long label for the UCSC trackhub."
                },
                "ucsc_trackhub_hub": {
                    "type": "string",
                    "default": "ChIPTrackHub",
                    "description": "Hub string to use for UCSC trackhub.",
                    "pattern": "^[a-zA-Z0-9]+$"
                },
                "email": {
                    "type": "string",
                    "description": "Email address to use for Trackhubs, etc.",
                    "pattern": "^([a-zA-Z0-9_\\-\\.]+)@([a-zA-Z0-9_\\-\\.]+)\\.([a-zA-Z]{2,5})$"
                }
            }
        },
        "deeptools_options": {
            "title": "DeepTools options",
            "type": "object",
            "description": "Options for DeepTools signal processing and analysis",
            "properties": {
                "bamcoverage_binsize": {
                    "type": "integer",
                    "default": 10,
                    "description": "bin size to use for bamCoverage."
                },
                "bamcoverage_normalize": {
                    "type": "string",
                    "default": "CPM",
                    "enum": [
                        "CPM",
                        "BPM"
                    ],
                    "description": "Normalization method to use for bamCoverage."
                },
                "skip_bamcoverage": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip bamCoverage."
                }
            }
        },
        "rgreat_options": {
            "title": "rGREAT options",
            "type": "object",
            "description": "Options for running rGREAT on output bed files.",
            "properties": {
                "skip_rgreat": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip rGREAT."
                },
                "great_libs": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "pattern": "^\\S+\\.csv$",
                    "description": "Path to CSV file containing information about the GREAT libraries to use.",
                    "default": null
                },
                "great_mode": {
                    "type": "string",
                    "default": "basalPlusExt",
                    "enum": [
                        "basalPlusExt",
                        "twoClosest",
                        "oneClosest"
                    ],
                    "description": "Mode to use for rGREAT."
                },
                "great_extension": {
                    "type": "integer",
                    "default": 1000000,
                    "description": "Extension to use for rGREAT."
                },
                "great_basal_upstream": {
                    "type": "integer",
                    "default": 5000,
                    "description": "Basal upstream region to use for rGREAT."
                },
                "great_basal_downstream": {
                    "type": "integer",
                    "default": 1000,
                    "description": "Basal downstream region to use for rGREAT."
                },
                "extend_tss_ext_args": {
                    "type": "string",
                    "default": "--type gene --gene-id-col gene_name --gene-id-type SYMBOL",
                    "description": "Extra arguments to pass to extend TSS."
                }
            }
        },
        "multiqc_options": {
            "title": "MultiQC options",
            "type": "object",
            "description": "Options for MultiQC report generation.",
            "properties": {
                "multiqc_config": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "description": "Path to multiqc config file.",
                    "default": "${projectDir}/assets/multiqc_config.yaml"
                }
            }
        },
        "summary_options": {
            "title": "Excel Summary options",
            "type": "object",
            "description": "Options for Excel summary generation.",
            "properties": {
                "summary_config": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "description": "Path to summary config file.",
                    "default": "${projectDir}/assets/summary_metrics.yaml"
                },
                "summary_motifs": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "description": "Path to YAML file listing key motifs for each group.",
                    "default": null
                }
            }
        },
        "process_options": {
            "title": "Process options",
            "type": "object",
            "description": "Options for process execution.",
            "properties": {
                "max_cpus": {
                    "type": "integer",
                    "default": 100,
                    "description": "Maximum number of CPUs to use."
                },
                "max_memory": {
                    "type": "string",
                    "default": "128.GB",
                    "description": "Maximum amount of memory to use."
                },
                "max_walltime": {
                    "type": "string",
                    "default": "72.h",
                    "description": "Maximum amount of time to use."
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/defs/input_output_options"
        }
    ]
}