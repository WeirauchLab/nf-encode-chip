/*
pipeline details
*/

manifest {
	author = "Andrew VonHandorf"
	defaultBranch = "master"
	description = "ENCODE ChIP-seq pipeline translated into Nextflow with modifications"
	homePage = "https://github.com/WeirauchLab/nf-encode-chip"
	mainScript = "main.nf"
	nextflowVersion = ">=24.10.0"
	version = "1.3.0"
}

/*
nextflow settings
*/

nextflow.enable.moduleBinaries = true
nextflow.preview.output        = true

plugins {
	id 'nf-schema@2.0.0'
}

/*
pipeline parameters
*/

params {
	//input/output options
	input                    = null
	outdir                   = null
	fasta                    = null
	genome                   = null
	gtf                      = null
	mito_chr_name            = "chrM"
	bowtie2_index            = null
	pseudorep_seed           = 42
	exclusion_peaks	         = null
	save_reference           = false

	// fastq options
	skip_adapter_trimming       = false
	save_trimmed_fastq          = false
	adapter_1                   = null
	adapter_2                   = null
	fastp_extra_args            = null
	fastp_detect_adapter_for_pe = false
	seqkit_seed                 = 12345
	save_subsampled_fastq       = false

	// alignment options
	skip_align              = false
	aligner                 = "bowtie2"
	local_mode              = false
	mapq_threshold	        = 30
	spp_subsample_fragments = 10000000
	skip_low_mapq_filter    = false
	skip_rm_duplicates      = false
	save_filtered_bam       = true
	skip_pseudoreplication  = false
	save_sample_tagalign    = true
	save_pr_tagalign        = false
	save_pooled_tagalign    = true
	markdup_method          = "sambamba"
	
	// ENCODE options
	use_encode_overlap      = false

	//metagenomics options
	kraken2_db            = "https://genome-idx.s3.amazonaws.com/kraken/k2_viral_20240605.tar.gz"
	kraken2_ext_args      = "--output - --report-minimizer-data --use-names"
	skip_kraken2          = false
	skip_sourmash	      = true
	sourmash_db           = null
	sourmash_ext_args     = "-p abund"

	// homer options
	skip_homer_findmotifsgenome     = false
	homer_log2_mode                 = false
	homer_motif_lib                 = null
	skip_homer_annotatepeaks        = false
	homer_findmotifsgenome_ext_args = "-size given -nomotif"

	// trackhub options
	email                    = null
	ucsc_trackhub_hub        = "ChIPTrackHub"
	ucsc_trackhub_shortlabel = "ChIP-seq"
	ucsc_trackhub_longlabel  = "ChIP-seq data"

	// encode peak options
	gensz                       = null
	encode_macs2_pthresh        = 0.01
	encode_macs2_ext_args       = "-f BED -p 0.01 --nomodel --shift 0 --keep-dup all"
	skip_peak_filtering         = false
	chr_filter                  = 'chr[0-9XY]+'
	encode_max_macs2_peaks      = 500000
	encode_macs2_post_qfilter   = 0.05

	// encode options

	// encode reproducibility options
	idr_threshold_col    = "p.value"
	idr_threshold        = 0.05
	idr_extra_args       = "--use-best-multisummit-IDR"
	skip_idr             = false
	skip_overlap         = false

	// deeptools options
	bamcoverage_binsize   = 10
	bamcoverage_normalize = "CPM"
	skip_bamcoverage      = false

	// rGREAT options
	skip_rgreat = false
	great_libs = null
	great_mode = "basalPlusExt"
	great_extension = 1000000
	great_basal_upstream = 5000
	great_basal_downstream = 1000
	extend_tss_ext_args = "--type gene --gene-id-col gene_name --gene-id-type SYMBOL"

	// multiqc options
	multiqc_config       = "${projectDir}/assets/multiqc_config.yaml"

	// excel summary options
	summary_config       = "${projectDir}/assets/summary_metrics.yaml"
	summary_motifs       = null

	// process options
	max_cpus             = 100
	max_memory           = 128.GB
	max_walltime         = 72.h
}

profiles {
	conda {
		conda.enabled       = true
		singularity.enabled = false
		docker.enabled      = false
		apptainer.enabled   = false
	}
	docker {
		conda.enabled       = false
		singularity.enabled = false
		docker.enabled      = true
		apptainer.enabled   = false
		//docker.runOptions   = '-u $(id -u):$(id -g)'
	}
	singularity {
		conda.enabled       = false
		singularity.enabled = true
		singularity.autoMounts = true
		docker.enabled      = false
		apptainer.enabled   = false
	}

	test { includeConfig "${projectDir}/conf/test.config" }
}

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}

// Capture exit codes from upstream processes when piping
// This has to be disabled due to SPP for now.
//process.shell = ['/bin/bash', '-euo', 'pipefail']

// Disable process selector warnings by default. Use debug profile to enable warnings.
nextflow.enable.configProcessNamesValidation = false

/*
workflow outputs
*/

outputDir = params.outdir
workflow.output.mode = 'copy'
workflow.output.overwrite = true


/*
workflow introspection
*/

def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.mmd"
}

/*
Additional checks
*/



/*
process directives
*/

process {
    resourceLimits = [
        cpus: params.max_cpus,
        memory: params.max_memory,
        time: params.max_walltime
    ]
}

process {

	withName: "SEQKIT_SAMPLE" {
		ext.args = {
			[
				params.seqkit_seed ? "--rand-seed ${params.seqkit_seed}" : "",
				meta.subsample_prop < 1 ? "--proportion ${meta.subsample_prop}" : ""
			].join(" ").trim()
		}
	}

	withName: "FASTP_FASTP" {
		ext.args = {
			[
				params.fastp_detect_adapter_for_pe ? "--detect_adapter_for_pe" : "",
				meta.adapter_1 ? "--adapter_sequence ${meta.adapter_1}" : "",
				meta.adapter_2 ? "--adapter_sequence_r2 ${meta.adapter_2}" : "",
				params.fastp_extra_args ? params.fastp_extra_args : ""
			].join(" ").trim()
		}
	}
	
	withName: "BOWTIE2_BUILD" {
		ext.args = [
			""
		].join(" ").trim()
	}
	withName: "BOWTIE2_ALIGN" {
		ext.args = {
			[
				params.local_mode ? "--local" : "",
				!meta.single_end ? "-X2000" : ""
			].join(" ").trim()
		}
	}

	withName: "QFILTER_PEAKS" {
		ext.args = {
			[
				params.encode_macs2_post_qfilter ? "--q-threshold ${params.encode_macs2_post_qfilter}" : ""
			].join(" ").trim()
		}
		ext.prefix = {
			params.encode_macs2_post_qfilter ? "qfilt-${params.encode_macs2_post_qfilter}_${meta.id}": "qfilt_${meta.id}"
		}
	}

	withName: "RUN_SPP" {
		ext.subsample_n_reads = params.spp_subsample_fragments ?: 0
	}

	if(!params.skip_homer_findmotifsgenome) {
		withName: "HOMER_FINDMOTIFSGENOME" {

			ext.args = {
				[
					params.homer_findmotifsgenome_ext_args ? params.homer_findmotifsgenome_ext_args : ""
				].join(" ").trim()
			}
			if (params.homer_log2_mode){
				container = "quay.io/andvon/homer_log2:2870c2b"
			}
		}
	}
	withName: "MACS2_CALLPEAK" {
		ext.args = {
			[
				params.encode_macs2_ext_args ? params.encode_macs2_ext_args : "",
				meta.frag_len && meta.frag_len > 0 ? "--extsize ${meta.frag_len}" : ""
			].join(" ").trim()
		}
	}

	withName: "OVERLAP_PEAKS" {
		ext.use_encode_overlap = params.use_encode_overlap
	}

	withName: "IDR_PEAKS" {
		errorStrategy = { task.exitStatus == 1 ? 'ignore' : 'retry' }
		ext.args = {
			[
				params.idr_extra_args ? params.idr_extra_args : ""
			].join(" ").trim()
		}
	}

	if(!params.skip_sourmash){
		withName: "SOURMASH_SKETCH" {
			ext.args = {
				[
					params.sourmash_ext_args ? params.sourmash_ext_args : ""
				].join(" ").trim()
			}
		}
	}

	if(!params.skip_bamcoverage){
		withName: "DEEPTOOLS_BAMCOVERAGE" {
			ext.args = {
				[
					params.bamcoverage_binsize   ? "--binSize ${params.bamcoverage_binsize}" : "",
					params.bamcoverage_normalize ? "--normalizeUsing ${params.bamcoverage_normalize}" : ""
				].join(" ").trim()
			}
		}
	}

	

	if(!params.skip_kraken2){
		withName: "KRAKEN2_KRAKEN2" {
			ext.args = params.kraken2_ext_args ? params.kraken2_ext_args : ""
		}
	}

	withName: "CREATE_PSEUDOREPS" {
		ext.args = {
			[
				params.pseudorep_seed ? "--seed ${params.pseudorep_seed}" : ""
			].join(" ").trim()
		}
	}

	withName: "LIB_QC" {
		ext.chr_filter = params.mito_chr_name ? params.mito_chr_name : ""
	}

	withName: "UCSC_BEDTOBIGBED" {
		ext.args = "-tab"
	}
	withName: "UCSC_TRACKHUB" {
		ext.args = {
			[
				params.genome ? "--genome ${params.genome}" : "",
				params.email  ? "--email '${params.email}'" : "",
				params.ucsc_trackhub_shortlabel ? "--shortLabel '${params.ucsc_trackhub_shortlabel}'" : "",
				params.ucsc_trackhub_longlabel  ? "--longLabel '${params.ucsc_trackhub_longlabel}'" : "",
			].join(' ').trim()
		}
	}

	withName: "EXTEND_TSS" {
		ext.args = {
			[
				params.great_mode ? "--mode ${params.great_mode}" : "",
				params.great_extension ? "--extension ${params.great_extension}" : "",
				params.great_basal_upstream ? "--basal-upstream ${params.great_basal_upstream}" : "",
				params.great_basal_downstream ? "--basal-downstream ${params.great_basal_downstream}" : "",
				params.extend_tss_ext_args ?: ""
			].join(" ").trim()
		}
	}

	withName: "RGREAT_GREAT" {
		ext.args = {
			[
				"--peak-id ${meta.group}_${meta.reproducibility_mode}_${meta.reproducibility_class}",
				"--gmt-id ${meta.great_lib_id}"
			].join(" ").trim()
		}
	}
}
