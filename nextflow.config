nextflow.enable.moduleBinaries = true
nextflow.preview.output = true

params {
	input                = null
	outdir               = null
	fasta                = null
	gensz                = null
	mito_chr_name        = "chrM"
	mito_fasta           = null
	bowtie2_index        = null
	bowtie2_mito_index   = null
	chrom_sizes          = null
	multimapping         = null
	local_mode           = false
	read_length_reads    = 100
	mapq_threshold	     = 30
	chr_filter           = 'chr[0-9XY]+'
	pseudoreplicate_seed = 42
	blacklist_peaks	     = null
	chip_mode            = "tf"

	idr_threshold_col    = "p.value"
	idr_threshold        = 0.05

	deeptools_bamcoverage_args = "--binSize 10 --normalizeUsing CPM"

	sourmash_db          = null
	sourmash_params      = "k=31,abund"
	enable_sourmash	     = true

	multiqc_config       = "${projectDir}/assets/multiqc_config.yaml"


	publish_dir_mode     = "copy"
	max_cpus             = 100
	max_memory           = 128.GB
	max_walltime         = 72.h
}

profiles {
	conda {
		conda.enabled       = true
		singularity.enabled = false
		docker.enabled      = false
		apptainer.enabled   = false
	}
	docker {
		conda.enabled       = false
		singularity.enabled = false
		docker.enabled      = true
		apptainer.enabled   = false
		docker.runOptions   = '-u $(id -u):$(id -g)'
	}

	test { includeConfig "${projectDir}/conf/test.config" }
}

//includeConfig "${projectDir}/conf/modules.config"

manifest {
	author = "Andrew VonHandorf"
	defaultBranch = "master"
	description = "ENCODE ChIP-seq pipeline translated into Nextflow with modifications"
	homePage = "https://github.com/andvon/nf-encode-chip2"
	mainScript = "main.nf"
	nextflowVersion = ">=24.04.1"
	version = "0.0.1"
}

plugins {
	id 'nf-schema@2.0.0'
}

def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.mmd"
}

process {
    resourceLimits = [
        cpus: params.max_cpus,
        memory: params.max_memory,
        time: params.max_walltime
    ]
}